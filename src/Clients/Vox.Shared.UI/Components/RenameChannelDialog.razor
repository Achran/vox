@inject IChannelService ChannelService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
            Rename Channel
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Channel Name" Required="true"
                      RequiredError="Channel name is required" Variant="Variant.Outlined" />
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@_errorMessage</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="SubmitAsync" Disabled="@_submitting">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public Guid ChannelId { get; set; }

    [Parameter]
    public string Name { get; set; } = string.Empty;

    private string _name = string.Empty;
    private string? _errorMessage;
    private bool _submitting;

    protected override void OnParametersSet()
    {
        _name = Name;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _errorMessage = "Channel name is required.";
            return;
        }

        _submitting = true;
        _errorMessage = null;

        var result = await ChannelService.UpdateChannelAsync(ChannelId, _name.Trim());

        if (result is not null)
        {
            MudDialog.Close(DialogResult.Ok(result));
        }
        else
        {
            _errorMessage = ChannelService.ErrorMessage ?? "Failed to rename channel.";
        }

        _submitting = false;
    }
}
