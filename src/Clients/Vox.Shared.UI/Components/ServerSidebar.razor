@inject IServerService ServerService
@inject IDialogService DialogService

<div class="d-flex flex-column align-center gap-2 pa-2" style="width: 72px; background-color: var(--mud-palette-background-gray); height: 100%; overflow-y: auto;">
    @if (_loading)
    {
        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
    }
    else
    {
        @foreach (var server in _servers)
        {
            <MudTooltip Text="@server.Name" Placement="Placement.Right">
                <MudAvatar Color="@(server.Id == SelectedServerId ? Color.Primary : Color.Dark)"
                           Variant="Variant.Filled"
                           Size="Size.Large"
                           Style="cursor: pointer;"
                           @onclick="() => SelectServer(server)">
                    @if (!string.IsNullOrEmpty(server.IconUrl))
                    {
                        <MudImage Src="@server.IconUrl" Alt="@server.Name" />
                    }
                    else
                    {
                        @GetServerInitials(server.Name)
                    }
                </MudAvatar>
            </MudTooltip>
        }

        <MudDivider Class="my-1" Style="width: 40px;" />

        <MudTooltip Text="Create Server" Placement="Placement.Right">
            <MudIconButton Icon="@Icons.Material.Filled.Add"
                           Color="Color.Success"
                           Variant="Variant.Outlined"
                           Size="Size.Medium"
                           OnClick="OpenCreateDialogAsync" />
        </MudTooltip>
    }
</div>

@code {
    [Parameter]
    public Guid? SelectedServerId { get; set; }

    [Parameter]
    public EventCallback<ServerResponse> OnServerSelected { get; set; }

    [Parameter]
    public EventCallback OnServersChanged { get; set; }

    private List<ServerResponse> _servers = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadServersAsync();
    }

    public async Task LoadServersAsync()
    {
        _loading = true;
        StateHasChanged();

        var servers = await ServerService.GetUserServersAsync();
        _servers = servers.ToList();

        _loading = false;
        StateHasChanged();
    }

    private async Task SelectServer(ServerResponse server)
    {
        await OnServerSelected.InvokeAsync(server);
    }

    private async Task OpenCreateDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<CreateServerDialog>("Create Server",
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadServersAsync();
            if (result.Data is ServerResponse newServer)
            {
                await OnServerSelected.InvokeAsync(newServer);
            }
            await OnServersChanged.InvokeAsync();
        }
    }

    private static string GetServerInitials(string name)
    {
        var words = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length == 0) return "?";
        if (words.Length == 1) return words[0][..Math.Min(2, words[0].Length)].ToUpperInvariant();
        return $"{char.ToUpperInvariant(words[0][0])}{char.ToUpperInvariant(words[1][0])}";
    }
}
